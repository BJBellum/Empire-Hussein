# Token du bot Discord (onglet "Bot" sur discord.com/developers)
DISCORD_TOKEN=your_bot_token_here

# Client ID du bot (onglet "General Information")
CLIENT_ID=your_client_id_here

# ID du serveur Discord (clic droit sur le serveur > Copier l'identifiant)
GUILD_ID=your_guild_id_here

# IDs des admins Hussein (séparés par des virgules)
